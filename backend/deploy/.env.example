# =============================================================================
# ZitronSystem -- docker-compose environment variables
# Copy this file to .env and fill in real secret values before running compose.
# NEVER commit .env -- it is gitignored. Only .env.example is tracked.
# =============================================================================

# -- CardVault ----------------------------------------------------------------
# CardVault reads Jwt:SigningKey (env var Jwt__SigningKey).
# Must be >=32 characters and must NOT be a placeholder string.
Jwt__SigningKey=__REPLACE_ME__

# CardVault SQL Server connection string (CardVaultIdentity DB).
# The CardVaultIdentity database is created automatically by EF Identity
# migrations at service startup -- no manual init script required.
ConnectionStrings__SqlServerIdentity=__REPLACE_ME__

# CardVault Postgres connection string (cardvault DB).
# SEC-01: no live connection string ships in committed appsettings anymore --
# CardVault.Api fails fast at startup if this is absent from all config
# sources (see RequiredConnectionStringsOptionsValidator).
ConnectionStrings__Postgres=__REPLACE_ME__

# CardVault vault encryption key (SEC-01 rotation target).
# The new active vault key generated as part of the k1/k2 -> k3 rotation
# runbook (see backend/SECRETS-ROTATION-RUNBOOK.md). 32-byte AES-256-GCM key,
# Base64-encoded. Generate with a cryptographically secure RNG -- never reuse
# a previously committed/leaked value.
#
# Transition window only: k1/k2 may still be loaded alongside k3 while
# re-encryption is in progress (see the rotation runbook). Once the runbook's
# orphan-proof gate confirms COUNT(TokenVault WHERE KeyId NOT IN ('k3')) == 0
# and k1/k2 are revoked, only Vault__Keys__k3 remains required.
Vault__Keys__k3=__REPLACE_ME__
# Vault__Keys__k1=__REPLACE_ME__   # transition window only -- remove after re-encryption completes
# Vault__Keys__k2=__REPLACE_ME__   # transition window only -- remove after re-encryption completes
Vault__ActiveKeyId=k3

# CardVault Development-only admin seed (SEC-05).
# Only consumed when ASPNETCORE_ENVIRONMENT=Development. Never set these in
# Production -- the seed block is gated to Development and has no fallback.
Seed__AdminEmail=__REPLACE_ME__
Seed__AdminPassword=__REPLACE_ME__
Seed__OpenBankingClientSecret=__REPLACE_ME__

# -- IsoSwitch ----------------------------------------------------------------
# IsoSwitch reads Jwt:SigningKey (env var Jwt__SigningKey) -- same key as CardVault.
# Jwt__SigningKey already declared above; same value is used by IsoSwitch.

# IsoSwitch tokenization secret.
# Must be >=32 characters and must NOT be a placeholder string (SEC-1).
Tokenization__Secret=__REPLACE_ME__

# IsoSwitch Postgres connection string (isoswitch DB, created by init-databases.sql).
# W-1 fix: a single shared .env cannot hold two different Postgres databases.
# CardVault Postgres DB is set via an inline environment: override in docker-compose.yml
# (cardvault service) so it always points at Database=cardvault regardless of this value.
# IsoSwitch has no inline override and therefore uses this shared .env value directly.
ConnectionStrings__Postgres=__REPLACE_ME__

# IsoSwitch operator-supplied admin API key (SEC-11).
# Must NOT be the literal "dev-admin-key" placeholder -- IsoSwitch fails fast
# at startup if it is missing, empty, or equal to that known DEV literal.
Admin__ApiKey=__REPLACE_ME__

# -- IsoAudit -----------------------------------------------------------------
# IMPORTANT: IsoAudit reads Jwt:Key (env var Jwt__Key) -- NOT Jwt:SigningKey.
# This asymmetry is intentional and preserved unchanged (CICD-INV-6).
# Must be >=32 characters and must NOT be a placeholder string.
Jwt__Key=__REPLACE_ME__
# IsoAudit Issuer/Audience -- must match CardVault Jwt:Issuer / Jwt:Audience
# Defaults ship in appsettings.json ("CardVault" / "CardSwitch").
# Override here only if CardVault Jwt:Issuer or Jwt:Audience are changed.
Jwt__Issuer=CardVault
Jwt__Audience=CardSwitch

# IsoAudit reads GetConnectionString(IsoSwitchDb) (env var ConnectionStrings__IsoSwitchDb).
# IsoAudit reads from the isoswitch Postgres database -- NOT a separate DB.
ConnectionStrings__IsoSwitchDb=__REPLACE_ME__

# -- CORS (optional for local dev) --------------------------------------------
Cors__AllowedOrigins__0=http://localhost:4200
