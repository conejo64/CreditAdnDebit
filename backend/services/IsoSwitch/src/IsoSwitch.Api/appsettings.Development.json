{
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200"]
  },
  "Jwt": {
    "Issuer": "CardVault",
    "Audience": "CardSwitch",
    "SigningKey": ""
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ClientId": "isoswitch",
    "GroupId": "isoswitch-config",
    "Topics": {
      "SwitchEvents": "sw.tx.updated",
      "TxEvents": "sw.tx.events",
      "IsoEvents": "sw.iso.events",
      "PciAudit": "sw.audit.pci"
    },
    "Consumers": {
      "PciAuditEnabled": true
    },
    "SigningSecret": "dev-signing-secret",
    "Retry": {
      "Max": 3,
      "Suffix": ".retry"
    },
    "Dlq": {
      "Suffix": ".dlq"
    },
    "RetryRepublisher": {
      "Enabled": true,
      "GroupId": "isoswitch-retry-republisher",
      "BaseDelayMs": 500,
      "MaxDelayMs": 30000
    }
  },
  "IsoSimulator": {
    "Enabled": true,
    "Port": 5005
  },
  "IsoClient": {
    "Host": "127.0.0.1",
    "Port": 5005,
    "TimeoutMs": 3000
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Iso": {
    "AcqInstId": "12345678901",
    "FwdInstId": "10987654321",
    "Connectors": {
      "Connectors": {
        "SIMULATOR": {
          "AcqInstId": "11111111111",
          "FwdInstId": "22222222222"
        }
      }
    }
  },
  "Connectors": {
    "TcpGateway": {
      "Host": "127.0.0.1",
      "Port": 5005,
      "UseTls": false,
      "AllowInvalidCert": true,
      "TimeoutMs": 3000,
      "RetryCount": 1,
      "CircuitBreaker": {
        "FailureThreshold": 5,
        "BreakSeconds": 15
      }
    }
  },
  "Admin": {
    "ApiKey": ""
  },
  "OpenTelemetry": {
    "ServiceName": "IsoSwitch.Api",
    "OtlpEndpoint": "http://localhost:4317",
    "ConsoleExporter": true
  }
}
