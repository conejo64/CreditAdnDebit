{
  "ConnectionStrings": {
    "Postgres": "",
    "SqlServerIdentity": ""
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ClientId": "cardvault",
    "SigningSecret": "dev-signing-secret",
    "Brokers": "localhost:9092",
    "SwitchConsumer": {
      "Enabled": true,
      "Topic": "sw.tx.events",
      "GroupId": "cardvault-switch-consumer"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Jwt": {
    "Issuer": "CardVault",
    "Audience": "CardSwitch",
    "SigningKey": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14
  },
  "Seed": {
    "AdminEmail": "",
    "AdminPassword": "",
    "OpenBankingClientSecret": ""
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Vault": {
    "ActiveKeyId": "",
    "Keys": {}
  },
  "VaultJob": {
    "Enabled": true,
    "IntervalMinutes": 10,
    "BatchSize": 200
  },
  "Pci": {
    "LogSensitiveData": false,
    "MaskPanLevel": "FIRST6_LAST4"
  },
  "OpenTelemetry": {
    "ServiceName": "CardVault.Api",
    "OtlpEndpoint": "http://localhost:4317",
    "ConsoleExporter": true
  }
}
