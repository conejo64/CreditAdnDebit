{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "CardVault",
    "Audience": "CardSwitch",
    "SigningKey": "CHANGE_ME_IN_PRODUCTION_32_CHARS_MIN",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14
  },
  "Vault": {
    "AdminRateLimit": {
      "PermitLimit": 20,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Notifications": {
    "Dispatcher": {
      "RealProvidersEnabled": false,
      "MaxAttempts": 3,
      "LockTtlMinutes": 5,
      "BatchSize": 50
    },
    "Webhook": {
      "RateLimits": {
        "sendgrid": 600,
        "twilio": 300,
        "movistar-ec": 120,
        "unknown": 60
      }
    },
    "Providers": {
      "Twilio": {
        "AccountSid": "",
        "FromNumber": "",
        "StatusCallbackUrl": ""
      },
      "SendGrid": {
        "FromEmail": "",
        "FromName": "CardVault",
        "TemplateIdMap": {
          "Otp": "",
          "TransactionNotification": "",
          "SecurityAlert": "",
          "StatementAvailable": "",
          "PaymentReceived": ""
        }
      },
      "MovistarEc": {
        "BaseUrl": "https://sms.movistar.ec",
        "SenderId": "CardVault",
        "UseRestProtocol": false,
        "DegradedConfirmation": false,
        "SoapEndpointPath": "/ws/sms/v1",
        "RestEndpointPath": "/api/v1/sms/send",
        "SoapNamespace": "http://sms.movistar.ec/gateway/v1"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
