@model CardVault.Application.Services.Notifications.Templates.TemplateModel
<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Transaction notification</title></head>
<body>
<p>A transaction has been recorded on your card.</p>
@if (!string.IsNullOrEmpty(Model.MaskedPan))
{
    <p>Card: @Model.MaskedPan</p>
}
@if (Model.Amount.HasValue)
{
    <p>Amount: <strong>@Model.Amount!.Value.ToString("F2") @Model.CurrencyCode</strong></p>
}
@if (!string.IsNullOrEmpty(Model.MaskedMerchant))
{
    <p>Merchant: @Model.MaskedMerchant</p>
}
@if (Model.Timestamp.HasValue)
{
    <p style="color:#888;font-size:0.85em;">Date: @Model.Timestamp.Value.ToString("MM/dd/yyyy HH:mm") UTC</p>
}
<p>If you do not recognize this transaction, please contact us immediately.</p>
</body>
</html>
