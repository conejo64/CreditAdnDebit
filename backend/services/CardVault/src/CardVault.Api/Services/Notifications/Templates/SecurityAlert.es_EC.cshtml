@model CardVault.Api.Services.Notifications.Templates.TemplateModel
<!DOCTYPE html>
<html lang="es">
<head><meta charset="UTF-8"><title>Alerta de seguridad</title></head>
<body>
<p><strong>Alerta de seguridad en tu cuenta.</strong></p>
<p>Hemos detectado actividad inusual en tu cuenta.</p>
@if (Model.Timestamp.HasValue)
{
    <p style="color:#888;font-size:0.85em;">Fecha y hora: @Model.Timestamp.Value.ToString("dd/MM/yyyy HH:mm") UTC</p>
}
@if (!string.IsNullOrEmpty(Model.AdditionalData))
{
    <p>@Model.AdditionalData</p>
}
<p>Si fuiste tú, puedes ignorar este mensaje. De lo contrario, contáctanos de inmediato.</p>
</body>
</html>
