@model CardVault.Application.Services.Notifications.Templates.TemplateModel
<!DOCTYPE html>
<html lang="es">
<head><meta charset="UTF-8"><title>Estado de cuenta disponible</title></head>
<body>
<p>Tu estado de cuenta está disponible.</p>
@if (!string.IsNullOrEmpty(Model.MaskedPan))
{
    <p>Tarjeta: @Model.MaskedPan</p>
}
@if (Model.Amount.HasValue)
{
    <p>Saldo total: <strong>@Model.Amount!.Value.ToString("F2") @Model.CurrencyCode</strong></p>
}
@if (Model.Timestamp.HasValue)
{
    <p style="color:#888;font-size:0.85em;">Período: @Model.Timestamp.Value.ToString("MMMM yyyy")</p>
}
<p>Ingresa a tu aplicación para ver el detalle.</p>
</body>
</html>
