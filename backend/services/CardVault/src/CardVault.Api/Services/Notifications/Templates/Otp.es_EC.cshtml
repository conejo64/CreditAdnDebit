@model CardVault.Application.Services.Notifications.Templates.TemplateModel
<!DOCTYPE html>
<html lang="es">
<head><meta charset="UTF-8"><title>Código de verificación</title></head>
<body>
<p>Tu código de verificación es:</p>
<p style="font-size:2em;font-weight:bold;letter-spacing:0.2em;">@Model.OtpCode</p>
<p>Este código es válido por 5 minutos. No lo compartas con nadie.</p>
@if (Model.Timestamp.HasValue)
{
    <p style="color:#888;font-size:0.85em;">Generado: @Model.Timestamp.Value.ToString("dd/MM/yyyy HH:mm") UTC</p>
}
</body>
</html>
