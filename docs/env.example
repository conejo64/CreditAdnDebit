# =============================================================================
# ZitronSystem — Required secrets per service
# =============================================================================
# NEVER commit real secrets. Use dotnet user-secrets for local dev.
# For CI/CD set these as environment variables before dotnet test / deploy.
# See docs/secrets.md for full provisioning instructions.
# =============================================================================

# --- CardVault.Api (Jwt:SigningKey) ---
Jwt__SigningKey=<replace-with-32-plus-char-random-secret>

# --- IsoSwitch.Api (Tokenization:Secret) ---
Tokenization__Secret=<replace-with-32-plus-char-random-secret>

# --- IsoAudit.Api (Jwt:Key) — must match CardVault Jwt__SigningKey ---
Jwt__Key=<replace-with-same-value-as-CardVault-Jwt__SigningKey>
# IsoAudit Issuer/Audience — must match CardVault Jwt:Issuer / Jwt:Audience
# Defaults ship in appsettings.json ("CardVault" / "CardSwitch").
# Override here only if CardVault Jwt:Issuer or Jwt:Audience are changed.
Jwt__Issuer=CardVault
Jwt__Audience=CardSwitch

# --- CORS allowlist (all 3 services) ---
# Empty array in appsettings.json = no CORS in production until origins are provisioned.
# Add one env var per allowed origin using array index notation (__0, __1, ...).
# Dev origins are provided in appsettings.Development.json (http://localhost:4200 for
# CardVault and IsoAudit). Override in CI/prod as needed.
Cors__AllowedOrigins__0=https://app.yourdomain.com
